    "@vitejs/plugin-react": "^4.3.4",
    "terser": "^5.46.0",
    "vite": "^6.2.1",
    "wrangler": "^4.70.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "Chrome >= 70",
